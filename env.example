# Copy this to ~/.config/rheem/env (or $XDG_CONFIG_HOME/rheem/env) and fill in.
#   mkdir -p ~/.config/rheem && cp env.example ~/.config/rheem/env
#   chmod 600 ~/.config/rheem/env
# Values already set in the real environment take precedence over this file.
#
# Rheem EcoNet mobile-app credentials (the account the heater is registered to)
ECONET_EMAIL=you@example.com
ECONET_PASSWORD=your-econet-app-password

# Datadog (optional). If DD_API_KEY is unset, the collector still logs to
# parquet and just skips the metric push.
DD_API_KEY=
# Needed only by dashboard.py to create/update the dashboard, not by the collector.
DD_APP_KEY=
# e.g. datadoghq.com (US1, default), datadoghq.eu, us5.datadoghq.com
DD_SITE=datadoghq.com

# --- Unit calibration (optional; shown values are the defaults) ---
# Usable hot water: the availability index is coarse (0/33/66/100) and 66
# is this unit's normal "full" step, so 66 -> RHEEM_USABLE_GALLONS.
RHEEM_FULL_INDEX=66
RHEEM_USABLE_GALLONS=80
RHEEM_TANK_GALLONS=80
# Estimated power model (no native power; runtime x assumed kW).
RHEEM_HP_KW=0.45
RHEEM_ELEMENT_KW=4.5
# Weather (Open-Meteo, no API key). Default coords = ZIP 97501.
RHEEM_LAT=42.3265
RHEEM_LON=-122.8756
# RHEEM_DISABLE_WEATHER=1   # uncomment to skip the outdoor-temp fetch
